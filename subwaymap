<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>東京地鐵站代號 · 每日路線</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0f0c09; --surface:#1a1410; --card:#221c16;
  --border:rgba(255,255,255,0.07);
  --gold:#C9922A; --gold-lt:#e8b86d; --red:#c0392b;
  --cream:#f5ede0; --muted:rgba(245,237,224,0.45);
  --green:#7ec8a0;
  --E:#B5121B; --A:#EF8200; --S:#5FAD41; --G:#F39700;
  --H:#888; --F:#8B5E31; --M:#E82020; --Z:#009BBF;
  --U:#00A89A; --JC:#F15A22; --OD:#009F6B; --TX:#555;
}
*{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px;-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--cream);font-family:'Noto Sans TC',sans-serif;padding-bottom:48px}

/* HEADER */
.header{background:linear-gradient(135deg,#1a0a04,#2d1608,#1a0a04);border-bottom:2px solid var(--gold);padding:18px 16px 14px;position:sticky;top:0;z-index:50}
.header-title{font-size:1.2rem;font-weight:700;color:var(--gold-lt)}
.header-sub{font-size:.68rem;color:var(--muted);letter-spacing:.15em;font-family:'Space Mono',monospace;margin-top:2px}
.day-tabs{display:flex;gap:6px;overflow-x:auto;padding-top:12px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.day-tabs::-webkit-scrollbar{display:none}
.tab{flex-shrink:0;padding:6px 14px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'Space Mono',monospace;font-size:.7rem;font-weight:700;cursor:pointer;transition:all .2s;border-radius:2px;letter-spacing:.05em}
.tab.active{background:var(--gold);border-color:var(--gold);color:#1a0a04}

/* MAIN */
main{padding:14px}
.day-section{display:none}
.day-section.active{display:block}

/* DAY HERO */
.day-hero{background:var(--surface);border-left:4px solid var(--gold);padding:13px 16px;margin-bottom:12px}
.day-label{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.2em;color:var(--gold);text-transform:uppercase;margin-bottom:3px}
.day-name{font-size:1.1rem;font-weight:700;line-height:1.3}
.day-desc{font-size:.76rem;color:var(--muted);margin-top:3px;line-height:1.6}

/* ROUTE CARD */
.route-card{background:var(--card);border:1px solid var(--border);margin-bottom:10px;overflow:hidden}
.route-header{display:flex;align-items:center;gap:8px;padding:9px 14px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--border)}
.move-num{font-family:'Space Mono',monospace;font-size:.65rem;color:var(--muted);flex-shrink:0;width:20px}
.move-label{font-size:.78rem;font-weight:700;flex:1}
.tbadge{font-family:'Space Mono',monospace;font-size:.6rem;font-weight:700;padding:2px 8px;border-radius:2px;flex-shrink:0;color:white}
.tb-E{background:var(--E)} .tb-A{background:var(--A)} .tb-S{background:var(--S);color:#111}
.tb-G{background:var(--G);color:#111} .tb-H{background:var(--H)}
.tb-F{background:var(--F)} .tb-M{background:var(--M)} .tb-U{background:var(--U)}
.tb-JC{background:var(--JC)} .tb-OD{background:var(--OD)} .tb-TX{background:var(--TX)}
.tb-walk{background:#1e3a1e;color:var(--green)}

/* STATION ROW */
.station-row{display:grid;grid-template-columns:1fr 32px 1fr;align-items:center;gap:4px;padding:12px 14px}
.sbox{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:10px 10px 8px;min-width:0}
.srole{font-family:'Space Mono',monospace;font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;margin-bottom:4px}
.srole.dep{color:var(--gold)} .srole.arr{color:var(--green)}
.sname{font-size:.95rem;font-weight:700;line-height:1.25;margin-bottom:4px}
.scodes{display:flex;flex-wrap:wrap;gap:3px}
.chip{font-family:'Space Mono',monospace;font-size:.72rem;font-weight:700;padding:2px 7px;border-radius:2px;color:white;display:inline-block}
.cE{background:var(--E)} .cA{background:var(--A)} .cS{background:var(--S);color:#111}
.cG{background:var(--G);color:#111} .cH{background:var(--H)} .cF{background:var(--F)}
.cM{background:var(--M)} .cZ{background:var(--Z)} .cU{background:var(--U)}
.cJC{background:var(--JC)} .cOD{background:var(--OD)} .cTX{background:var(--TX)}
.sexit{margin-top:5px;font-size:.72rem;background:rgba(255,255,255,.07);display:inline-block;padding:2px 7px}
.arrow-col{display:flex;flex-direction:column;align-items:center;gap:2px}
.arrow-icon{font-size:1.1rem;color:var(--muted)}
.walk-tag{font-family:'Space Mono',monospace;font-size:.5rem;color:var(--muted);text-align:center;line-height:1.4}

/* sub-note inside card */
.card-sub{padding:0 14px 12px;font-size:.74rem;color:var(--muted);line-height:1.7}
.card-sub span{color:var(--cream)}

/* NOTE BARS */
.nbar{margin:0 14px 10px;padding:9px 12px;font-size:.75rem;line-height:1.65;border-left:3px solid}
.nbar.warn{background:rgba(192,57,43,.12);border-color:var(--red);color:#f5a49b}
.nbar.info{background:rgba(201,146,42,.1);border-color:var(--gold);color:var(--gold-lt)}
.nbar strong{color:white}

/* SECTION DIVIDER within a page */
.day-divider{border:none;border-top:1px solid rgba(201,146,42,.3);margin:16px 0 12px}

/* LEGEND */
.legend-sec{margin:16px 0 0;border-top:1px solid var(--border);padding-top:14px}
.legend-title{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.2em;color:var(--muted);text-transform:uppercase;margin-bottom:10px}
.legend-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.legend-item{display:flex;align-items:center;gap:8px;background:var(--card);padding:8px 10px;border:1px solid var(--border)}
.ldot{width:28px;height:22px;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:.65rem;font-weight:700;color:white;flex-shrink:0;border-radius:2px}
.lcode{font-family:'Space Mono',monospace;font-size:.65rem;color:var(--gold);font-weight:700}
.lname{font-size:.72rem;color:var(--muted);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* KEY STATION CARD */
.keybox{background:var(--card);border:1px solid var(--border);padding:13px 14px;margin-bottom:8px}
.keybox-warn{background:rgba(192,57,43,.1);border:1px solid rgba(192,57,43,.3);padding:13px 14px}

.page-footer{text-align:center;padding:22px 16px 4px;font-family:'Space Mono',monospace;font-size:.6rem;color:var(--muted);letter-spacing:.1em}
</style>
</head>
<body>

<div class="header">
  <div class="header-title">🚇 東京地鐵 · 每日路線</div>
  <div class="header-sub">TOKYO 2026 · 6/21–6/27 · 站名代號速查</div>
  <div class="day-tabs">
    <button class="tab active" onclick="showDay('d1',this)">D1</button>
    <button class="tab" onclick="showDay('d2',this)">D2</button>
    <button class="tab" onclick="showDay('d3',this)">D3</button>
    <button class="tab" onclick="showDay('d4',this)">D4</button>
    <button class="tab" onclick="showDay('d5',this)">D5</button>
    <button class="tab" onclick="showDay('d6',this)">D6</button>
    <button class="tab" onclick="showDay('d7',this)">D7</button>
    <button class="tab" onclick="showDay('legend',this)">路線表</button>
